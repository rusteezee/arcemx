# OpenRouter (replaces deprecated google.generativeai SDK + Gemini key).
# Free tier: 20 req/min, 50 req/day. Sized for our 1/day cron + manual syncs.
# Default chain: Nemotron 3 Super (primary) -> Ultra (backup) -> nex-n2-pro
# (cross-provider safety net). Override via OPENROUTER_PRIMARY /
# OPENROUTER_FALLBACKS if needed.
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your_chat_id

# Reddit (optional, free)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=arcemx/0.1

# GNews (optional, 100/day free)
GNEWS_API_KEY=

# INDmoney MCP (auto-filled by indmoney_auth.py after first OAuth login)
INDMONEY_MCP_URL=https://mcp.indmoney.com/mcp
INDMONEY_TOKEN_FILE=.indmoney_tokens.json
